@page "/"
@using OmniCart.Infrastructure
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Navigation

<MudText Typo="Typo.h4" Class="font-weight-bold mb-6">Дашборд</MudText>

<MudGrid>
    <MudItem xs="12" sm="4">
        <MudPaper Elevation="1" Class="pa-4 rounded-lg d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.subtitle2" Class="text-secondary">Выручка</MudText>
                <MudText Typo="Typo.h4" Class="font-weight-bold mt-1">@_totalRevenue.ToString("N0") руб.</MudText>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Large" Color="Color.Primary" />
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="4">
        <MudPaper Elevation="1" Class="pa-4 rounded-lg d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.subtitle2" Class="text-secondary">Заказов сегодня</MudText>
                <MudText Typo="Typo.h4" Class="font-weight-bold mt-1">@_ordersToday</MudText>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Large" Color="Color.Secondary" />
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="4">
        <MudPaper Elevation="1" Class="pa-4 rounded-lg d-flex align-center justify-space-between">
            <div>
                <MudText Typo="Typo.subtitle2" Class="text-secondary">Всего клиентов</MudText>
                <MudText Typo="Typo.h4" Class="font-weight-bold mt-1">@_totalUsers</MudText>
            </div>
            <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Info" />
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="8">
        <MudPaper Class="pa-4 rounded-lg" Elevation="1">
            <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Статистика заказов за последние 7 дней</MudText>
            <MudChart ChartType="ChartType.Bar" ChartSeries="@_series" @bind-SelectedIndex="_index" ChartLabels="@_xAxisLabels" Width="100%" Height="350px"></MudChart>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="4">
        <MudPaper Class="pa-4 rounded-lg" Elevation="1" Style="height: 100%;">
            <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Популярные товары</MudText>
            <MudList T="string">
                @foreach (var item in _popularProducts)
                {
                    <MudListItem Icon="@Icons.Material.Filled.Star" IconColor="Color.Warning">
                        <div class="d-flex justify-space-between w-100">
                            <MudText>@item.Name</MudText>
                            <MudText Color="Color.Secondary" Class="ml-4">@item.Count шт.</MudText>
                        </div>
                    </MudListItem>
                }
            </MudList>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private decimal _totalRevenue;
    private int _ordersToday;
    private int _totalUsers;
    private int _index = -1;
    private HubConnection? _hubConnection;

    private List<ChartSeries<double>> _series = new();
    private string[] _xAxisLabels = Array.Empty<string>();
    private List<PopularProductDto> _popularProducts = new();

    private class PopularProductDto
    {
        public string Name { get; set; } = "";
        public int Count { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadStats();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/orderhub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On("NewOrderReceived", async () =>
        {
            await InvokeAsync(async () =>
            {
                await LoadStats();
                StateHasChanged();
            });
        });

        await _hubConnection.StartAsync();
    }

    private async Task LoadStats()
    {
        using var db = await DbFactory.CreateDbContextAsync();

        _totalRevenue = await db.Orders.SumAsync(o => o.TotalPrice);

        var todayUtc = DateTime.UtcNow.Date;
        _ordersToday = await db.Orders.CountAsync(o => o.CreatedAt >= todayUtc);

        _totalUsers = await db.Users.CountAsync();

        // Подготовка данных для графика (одним запросом)
        var sevenDaysAgo = todayUtc.AddDays(-6);

        var ordersData = await db.Orders
            .Where(o => o.CreatedAt >= sevenDaysAgo)
            .GroupBy(o => o.CreatedAt.Date)
            .Select(g => new { Date = g.Key, Count = g.Count() })
            .ToListAsync();

        var last7Days = Enumerable.Range(0, 7)
            .Select(i => sevenDaysAgo.AddDays(i))
            .ToList();

        _xAxisLabels = last7Days.Select(d => d.ToString("dd.MM")).ToArray();

        var orderCounts = last7Days.Select(d => (double)(ordersData.FirstOrDefault(od => od.Date == d)?.Count ?? 0)).ToArray();

        _series = new List<ChartSeries<double>>
        {
            new ChartSeries<double> { Name = "Заказы", Data = orderCounts }
        };

        // Популярные товары
        _popularProducts = await db.OrderItems
            .GroupBy(oi => oi.Product.Name)
            .Select(g => new PopularProductDto { Name = g.Key, Count = g.Sum(oi => oi.Quantity) })
            .OrderByDescending(x => x.Count)
            .Take(5)
            .ToListAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
