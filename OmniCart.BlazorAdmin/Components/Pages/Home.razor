@page "/"
@using OmniCart.Infrastructure
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.SignalR.Client
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@implements IAsyncDisposable

<MudText Typo="Typo.h3" GutterBottom="true">Панель управления</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center" Style="height: 150px; background-color: #594AE2; color: white;">
            <MudText Typo="Typo.h6">Выручка за всё время</MudText>
            <MudText Typo="Typo.h3">@_totalRevenue.ToString("N0") ₽</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center" Style="height: 150px; background-color: #00C853; color: white;">
            <MudText Typo="Typo.h6">Количество заказов</MudText>
            <MudText Typo="Typo.h3">@_totalOrders</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center justify-center" Style="height: 150px; background-color: #FF9100; color: white;">
            <MudText Typo="Typo.h6">Средний чек</MudText>
            <MudText Typo="Typo.h3">@_averageCheck.ToString("N0") ₽</MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <MudPaper Class="pa-4" Style="height: 450px;">
            <MudText Typo="Typo.h6" GutterBottom="true">Динамика продаж (последние 7 дней)</MudText>
            <div style="height: 350px;">
                <canvas id="salesChart"></canvas>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private decimal _totalRevenue;
    private int _totalOrders;
    private decimal _averageCheck;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/orderhub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<int, decimal, string>("NewOrder", async (orderId, total, customer) =>
        {
            await InvokeAsync(async () =>
            {
                await JSRuntime.InvokeVoidAsync("dashboard.playNotificationSound");
                await LoadData();
                StateHasChanged();
            });
        });

        await _hubConnection.StartAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RenderChart();
        }
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();

        _totalRevenue = await db.Orders.SumAsync(o => o.TotalPrice);
        _totalOrders = await db.Orders.CountAsync();
        _averageCheck = _totalOrders > 0 ? _totalRevenue / _totalOrders : 0;

        if (_hubConnection?.State == HubConnectionState.Connected)
        {
            await RenderChart();
        }
    }

    private async Task RenderChart()
    {
        using var db = await DbFactory.CreateDbContextAsync();

        var today = DateTime.UtcNow.Date;
        var sevenDaysAgo = today.AddDays(-6);

        var salesData = await db.Orders
            .Where(o => o.CreatedAt >= sevenDaysAgo)
            .GroupBy(o => o.CreatedAt.Date)
            .Select(g => new { Date = g.Key, Total = g.Sum(o => o.TotalPrice) })
            .ToListAsync();

        var labels = new List<string>();
        var data = new List<decimal>();

        for (int i = 0; i < 7; i++)
        {
            var date = sevenDaysAgo.AddDays(i);
            labels.Add(date.ToString("dd.MM"));
            data.Add(salesData.FirstOrDefault(s => s.Date == date)?.Total ?? 0);
        }

        await JSRuntime.InvokeVoidAsync("dashboard.renderSalesChart", "salesChart", labels, data);
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
