@page "/admin/orders"
@using OmniCart.Domain.Entities
@using OmniCart.Infrastructure
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudText Typo="Typo.h4" Class="font-weight-bold mb-4">Заказы</MudText>

    <MudTable Items="@_orders" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading" LoadingProgressColor="Color.Info" Elevation="1" Class="rounded-lg" Filter="new Func<Order,bool>(FilterFunc1)">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField @bind-Value="_searchString" Placeholder="Поиск заказа..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>ID</MudTh>
        <MudTh>Дата</MudTh>
        <MudTh>Клиент</MudTh>
        <MudTh>Адрес</MudTh>
        <MudTh>Сумма</MudTh>
        <MudTh>Статус</MudTh>
        <MudTh>Действия</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Дата">@context.CreatedAt.ToString("g")</MudTd>
        <MudTd DataLabel="Клиент">@context.User?.FirstName @context.User?.LastName (@context.User?.TelegramUserId)</MudTd>
        <MudTd DataLabel="Адрес">@context.DeliveryAddress</MudTd>
        <MudTd DataLabel="Сумма">@context.TotalPrice руб.</MudTd>
        <MudTd DataLabel="Статус">
            <MudChip T="string" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
        </MudTd>
        <MudTd DataLabel="Действия">
            <div class="d-flex align-center">
                <MudSelect T="string" Value="@context.Status" ValueChanged="@((s) => UpdateStatus(context, s))" Dense="true" Margin="Margin.Dense" Class="mr-2" Style="width: 150px;">
                    <MudSelectItem Value="@("Created")">Новый</MudSelectItem>
                    <MudSelectItem Value="@("Processing")">В обработке</MudSelectItem>
                    <MudSelectItem Value="@("Shipped")">Отправлен</MudSelectItem>
                    <MudSelectItem Value="@("Delivered")">Доставлен</MudSelectItem>
                    <MudSelectItem Value="@("Cancelled")">Отменен</MudSelectItem>
                </MudSelect>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteOrder(context))" Size="Size.Small" />
            </div>
        </MudTd>
    </RowTemplate>
</MudTable>
</MudContainer>

@code {
    private List<Order> _orders = new();
    private bool _loading = true;
    private string _searchString = "";
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/orderhub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On("NewOrderReceived", async () =>
        {
            await InvokeAsync(async () =>
            {
                await LoadOrders();
                StateHasChanged();
                Snackbar.Add("Получен новый заказ!", Severity.Success);
            });
        });

        await _hubConnection.StartAsync();
    }

    private async Task LoadOrders()
    {
        _loading = true;
        using var db = await DbFactory.CreateDbContextAsync();
        _orders = await db.Orders
            .Include(o => o.User)
            .OrderByDescending(o => o.CreatedAt)
            .ToListAsync();
        _loading = false;
    }

    private async Task UpdateStatus(Order order, string newStatus)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var existingOrder = await db.Orders.FindAsync(order.Id);
        if (existingOrder != null)
        {
            existingOrder.Status = newStatus;
            await db.SaveChangesAsync();
            order.Status = newStatus;
            Snackbar.Add($"Статус заказа #{order.Id} изменен на {newStatus}", Severity.Info);
        }
    }

    private async Task DeleteOrder(Order order)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var o = await db.Orders.FindAsync(order.Id);
        if (o != null)
        {
            db.Orders.Remove(o);
            await db.SaveChangesAsync();
            Snackbar.Add("Заказ удален", Severity.Success);
            await LoadOrders();
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Created" => Color.Info,
        "Processing" => Color.Warning,
        "Shipped" => Color.Primary,
        "Delivered" => Color.Success,
        "Cancelled" => Color.Error,
        _ => Color.Default
    };

    private bool FilterFunc1(Order order) => FilterFunc(order, _searchString);

    private bool FilterFunc(Order order, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (order.Id.ToString().Contains(searchString))
            return true;
        if (order.User?.FirstName.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            return true;
        if (order.User?.LastName?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            return true;
        if (order.User?.TelegramUserId.ToString().Contains(searchString) ?? false)
            return true;
        if (order.DeliveryAddress?.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            return true;
        if (order.Status.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
