@page "/admin/products"
@using OmniCart.Domain.Entities
@using OmniCart.Infrastructure
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar

<MudText Typo="Typo.h3" GutterBottom="true">Товары</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddProduct" StartIcon="@Icons.Material.Filled.Add" Class="mb-4">
    Добавить товар
</MudButton>

<MudTable Items="@_products" Hover="true" Breakpoint="Breakpoint.Sm" Loading="@_loading">
    <HeaderContent>
        <MudTh>ID</MudTh>
        <MudTh>Название</MudTh>
        <MudTh>Цена</MudTh>
        <MudTh>Остаток</MudTh>
        <MudTh>Действия</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Название">@context.Name</MudTd>
        <MudTd DataLabel="Цена">@context.Price руб.</MudTd>
        <MudTd DataLabel="Остаток">@context.Stock шт.</MudTd>
        <MudTd DataLabel="Действия">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" OnClick="@(() => EditProduct(context))" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => DeleteProduct(context))" />
        </MudTd>
    </RowTemplate>
</MudTable>

<MudDialog @bind-Visible="_dialogVisible" Options="_dialogOptions">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editingProduct.Id == 0 ? "Добавить товар" : "Редактировать товар")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_editingProduct.Name" Label="Название" Required="true" />
        <MudTextField @bind-Value="_editingProduct.Description" Label="Описание" Lines="3" />
        <MudNumericField @bind-Value="_editingProduct.Price" Label="Цена" Format="F2" Min="0" />
        <MudNumericField @bind-Value="_editingProduct.Stock" Label="Остаток на складе" Min="0" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Отмена</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveProduct">Сохранить</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<Product> _products = new();
    private bool _loading = true;
    private bool _dialogVisible;
    private Product _editingProduct = new() { Name = "", Description = "" };
    private readonly DialogOptions _dialogOptions = new() { FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        _loading = true;
        using var db = await DbFactory.CreateDbContextAsync();
        _products = await db.Products.OrderBy(p => p.Id).ToListAsync();
        _loading = false;
    }

    private void AddProduct()
    {
        _editingProduct = new Product { Name = "", Description = "", CreatedAt = DateTime.UtcNow };
        _dialogVisible = true;
    }

    private void EditProduct(Product product)
    {
        _editingProduct = new Product
        {
            Id = product.Id,
            Name = product.Name,
            Description = product.Description,
            Price = product.Price,
            Stock = product.Stock,
            CreatedAt = product.CreatedAt
        };
        _dialogVisible = true;
    }

    private async Task DeleteProduct(Product product)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var p = await db.Products.FindAsync(product.Id);
        if (p != null)
        {
            db.Products.Remove(p);
            await db.SaveChangesAsync();
            Snackbar.Add("Товар удален", Severity.Success);
            await LoadProducts();
        }
    }

    private void Cancel() => _dialogVisible = false;

    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(_editingProduct.Name))
        {
            Snackbar.Add("Название обязательно", Severity.Error);
            return;
        }

        using var db = await DbFactory.CreateDbContextAsync();
        if (_editingProduct.Id == 0)
        {
            db.Products.Add(_editingProduct);
        }
        else
        {
            db.Products.Update(_editingProduct);
        }

        await db.SaveChangesAsync();
        _dialogVisible = false;
        Snackbar.Add("Товар сохранен", Severity.Success);
        await LoadProducts();
    }
}